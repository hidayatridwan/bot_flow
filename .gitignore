# Secrets — .env holds LLM_API_KEY, ADMIN_API_KEY and the database/broker passwords.
# Commit .env.example instead, with the values blanked out.
.env
.env.*
!.env.example

# Rust build output. ~6.7 GB here; fully reproducible from Cargo.toml + Cargo.lock.
/target

# Embedding model weights, downloaded on first run by fastembed (~465 MB).
# Both binaries recreate this cache automatically.
.fastembed_cache/

# Python sidecar virtualenv. Rebuilt with:
#   python3 -m venv sidecar/.venv && sidecar/.venv/bin/pip install -r sidecar/requirements.txt
sidecar/.venv/
__pycache__/
*.py[cod]

# macOS
.DS_Store

# Editors
.idea/
.vscode/
*.swp

# Logs and local scratch
*.log


# Web
/web/node_modules

# Output
/web/.output
/web/.vercel
/web/.netlify
/web/.wrangler
/web/.svelte-kit
/web/build

# OS
/web/.DS_Store
/web/Thumbs.db

# Env
/web/.env
/web/.env.*
!/web/.env.example
!/web/.env.test

# Vite
/web/vite.config.js.timestamp-*
/web/vite.config.ts.timestamp-*