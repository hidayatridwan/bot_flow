# bot_flow — copy to `.env` and fill in the blanks.
#
#   cp .env.example .env
#
# `.gitignore` has expected this file since the beginning and it never existed, so every new
# contributor reconstructed the required set by reading `crates/api/src/config.rs`. This is that
# file, generated from it — **secrets are blank on purpose**; the non-secret values are the ones
# that line up with `docker-compose.yml`, so a local stack works as soon as the three keys are set.
#
# The web app has its own, separate: `web/.env.example`. It holds no secrets.
#
# Everything below is REQUIRED unless marked otherwise — the API exits at startup naming the first
# variable it cannot find, rather than failing later on the request that needed it.

# ─── Postgres ────────────────────────────────────────────────────────────────────────────────────
# Two URLs, two roles, and the split is a security boundary rather than tidiness. Migrations run as
# the owner; the runtime connects as `app_user`, a NON-SUPERUSER, because superusers bypass RLS
# entirely and tenant isolation would silently stop existing.
DATABASE_URL=postgres://bot_flow:bot_flow@localhost:5432/bot_flow
APP_DATABASE_URL=postgres://app_user:app_user@localhost:5432/bot_flow

# ─── Qdrant / RabbitMQ / Redis ───────────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6334
RABBITMQ_URL=amqp://bot_flow:bot_flow@localhost:5672/%2f
REDIS_URL=redis://localhost:6379

# ─── LLM ─────────────────────────────────────────────────────────────────────────────────────────
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_API_KEY=
# Optional. Default: gemini/gemini-2.5-flash-lite
# LLM_MODEL=

# ─── Embeddings ──────────────────────────────────────────────────────────────────────────────────
# A SEPARATE credential from LLM_API_KEY even when both point at the same gateway. There is
# deliberately no fallback: a silent one would send the chat key to the embeddings endpoint and then
# blame the endpoint for the 401.
EMBEDDING_BASE_URL=https://ai.sumopod.com/v1
EMBEDDING_API_KEY=
# Optional. Default: text-embedding-3-small. Changing it invalidates EVERY stored vector — that is a
# migration with a re-index, not a config edit.
# EMBEDDING_MODEL=

# ─── Object storage (MinIO / S3) ─────────────────────────────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
# What CLIENTS reach, signed into presigned URLs. Defaults to S3_ENDPOINT; they differ once the API
# talks to storage over an internal address.
# S3_PUBLIC_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
# Optional. Defaults: documents / us-east-1 / 900s / 25 MiB.
# S3_BUCKET=
# S3_REGION=
# PRESIGN_TTL_SECS=
# MAX_UPLOAD_BYTES=

# ─── Mail (password reset) ───────────────────────────────────────────────────────────────────────
# Required, and it fails at boot rather than silently: `/auth/password/forgot` answers 202 whether or
# not it sent anything, so a missing mailer would cost a locked-out user their account with nothing
# anywhere saying why.
#
# In development this is the Mailpit sink from docker-compose — read the mail at
# http://localhost:8025. Never point a dev box at a real relay: a reset link is a live credential.
SMTP_URL=smtp://localhost:1025
# Quote it — the angle brackets and the space need it, and dotenvy will not parse it otherwise.
MAIL_FROM="bot_flow <noreply@localhost>"
# Where reset links point: the WEB app, not the API. A user opens this in a browser.
APP_BASE_URL=http://localhost:5173

# ─── Admin & operations ──────────────────────────────────────────────────────────────────────────
# Guards /admin/*, which includes ERASING A TENANT. Any long random string; generate one with
#   openssl rand -hex 32
ADMIN_API_KEY=

# Optional, and NOT the admin key — that key can erase a tenant, and a scrape config is a
# widely-readable artifact. Unset means `GET /metrics` is not registered at all (a 404, not a 401).
# METRICS_TOKEN=

# ─── Tuning (all optional, all with measured or reasoned defaults) ───────────────────────────────
# BIND_ADDR=0.0.0.0:3000
# RATE_LIMIT_PER_MINUTE=60
# SESSION_TTL_SECS=2592000
# The relevance floor. 0.25 was MEASURED on the retrieval bench, not chosen — 0.35 looks reasonable
# and silently costs recall@3 1.000 -> 0.955. Re-sweep with `cargo run -p eval` before changing it.
# RAG_SCORE_THRESHOLD=0.25

# ─── Sidecar (worker only) ───────────────────────────────────────────────────────────────────────
PARSER_PYTHON=sidecar/.venv/bin/python
PARSER_SCRIPT=sidecar/parser.py

RUST_LOG=info,api=debug

# ─── Integration suite (optional) ────────────────────────────────────────────────────────────────
# Both are derived from the two URLs above by swapping the database name for `bot_flow_test`; set
# them only to point somewhere else. The second MUST be app_user — a superuser bypasses RLS, and
# every isolation test would pass without testing anything at all.
# TEST_DATABASE_URL=postgres://bot_flow:bot_flow@localhost:5432/bot_flow_test
# TEST_APP_DATABASE_URL=postgres://app_user:app_user@localhost:5432/bot_flow_test
